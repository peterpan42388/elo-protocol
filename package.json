{
  "name": "elo-protocol",
  "version": "0.1.0",
  "private": false,
  "description": "ELO protocol prototype for agent-to-agent settlement",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "demo": "node src/demo.js",
    "compile:solidity": "node scripts/compile-solidity.mjs",
    "start": "node src/apiServer.js",
    "test:contracts": "forge test -vv --match-path test/SettlementEngine.t.sol",
    "test:contracts:extreme": "FOUNDRY_PROFILE=extreme forge test -vvv",
    "policy:check": "bash scripts/check-repo-policy.sh",
    "deploy:local": "bash scripts/deploy-local-anvil.sh",
    "deploy:base-sepolia": "bash scripts/deploy-base-sepolia.sh",
    "integrate:risk:local": "bash scripts/integrate-private-risk-local.sh",
    "integrate:risk:base-sepolia": "bash scripts/integrate-private-risk-base-sepolia.sh",
    "wallet:virtual": "bash scripts/bootstrap-virtual-wallets.sh",
    "test:p0p2": "node --test tests/eloMarket.p0-p2.test.js",
    "test:p0p2:local": "bash scripts/run-p0-p2-local.sh",
    "demo:market": "node src/eloMarketDemo.js",
    "test:dashboard-contract": "node --test tests/dashboard.api-contract.test.js",
    "verify:p3a-freeze": "node scripts/verify-p3a-freeze.mjs",
    "verify:p4b-audit-prep": "node scripts/verify-p4b-audit-prep.mjs",
    "verify:p4c-security-review": "node scripts/verify-p4c-security-review.mjs"
  },
  "devDependencies": {
    "solc": "^0.8.30"
  },
  "license": "MIT"
}
